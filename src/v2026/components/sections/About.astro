---
import RunTux from '@/v2026/assets/tux-wizard_v2.svg'
---

<section id="about" class="about-section">
  <div class="about-shell">
    <header class="about-header">
      <p class="about-kicker">Sobre el evento</p>
      <h2>FLISOL 2026</h2>
    </header>

    <div class="about-content">
      <div class="about-image">
        <RunTux />
      </div>
      <div class="about-description">
        <p>
          El FLISoL (Festival Latinoamericano de Instalación de Software Libre) es un evento anual que
          busca difundir y <span class="highlighted">promover el Software Libre en Latinoamérica</span>.
          Es el evento de difusión de Software Libre más grande en el mundo hispanohablante.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    padding: 4.5rem 0.6rem 5.2rem;
    background: #130831;
  }

  .about-shell {
    width: min(1460px, calc(100vw - 1.2rem));
    margin: 0 auto;
  }

  .about-header {
    color: #f9f8ff;
    margin-bottom: 2.2rem;
    text-align: center;
  }

  .about-kicker {
    font-size: 0.72rem;
    color: #e9ba2d;
    margin-bottom: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
  }

  .about-header h2 {
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    color: #ffffff;
    margin-bottom: 0.8rem;
    line-height: 1.4;
    text-shadow: 2px 2px #18083b;
  }

  .about-content {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1rem;
  }

  .about-image {
    grid-column: 5 / 7;
    min-height: 350px;
    display: flex;
    justify-content: center;
    align-items: center;
    background: rgba(33, 10, 80, 0.4);
    border: 4px solid #4296ca;
    border-radius: 10px;
    box-shadow:
      0 0 0 4px #210a50,
      4px 4px 0 0 #e9ba2d,
      8px 8px 0 0 #000;
  }

  .about-description {
    grid-column: 1 / 5;
    padding: 2rem;
    background: rgba(33, 10, 80, 0.6);
    border: 4px solid #4296ca;
    border-radius: 10px;
    box-shadow:
      0 0 0 4px #210a50,
      4px 4px 0 0 #e9ba2d,
      8px 8px 0 0 #000;
  }

  .about-description p {
    color: #e0e0ff;
    font-size: 1.2rem;
    line-height: 1.6;
  }

  .highlighted {
    color: #e9ba2d;
    font-weight: bold;
    text-shadow:
      1px 0 #18083b,
      -1px 0 #18083b,
      0 1px #18083b,
      0 -1px #18083b;
  }

  @media screen and (max-width: 768px) {
    .about-content {
      display: flex;
      flex-direction: column;
      padding: 2rem 1rem;
    }

    .about-header h2 {
      font-size: 2.5rem;
    }

    .about-image,
    .about-description {
      width: 100%;
    }
  }
</style>